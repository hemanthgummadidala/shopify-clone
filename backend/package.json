{
  "name": "shopify-clone-backend",
  "version": "1.0.0",
  "description": "Backend for Shopify-like e-commerce website",
  "main": "dist/index.js",
  "scripts": {
    "db:start": "powershell -ExecutionPolicy Bypass -File ./run-postgres.ps1",
    "db:stop": "powershell -ExecutionPolicy Bypass -Command \"& './postgres-bin/bin/pg_ctl.exe' stop -D './postgres-data'\"",
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@google-cloud/bigquery": "^8.3.1",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.12.0",
    "shopify-clone": "file:.."
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.14.9",
    "@types/pg": "^8.20.0",
    "tsx": "^4.15.7",
    "typescript": "^5.5.2"
  }
}
